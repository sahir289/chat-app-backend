generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id                              String                  @id @default(cuid())
  name                            String
  slug                            String?                 @unique
  email                           String?
  phone                           String?
  logo                            String?
  createdBySuperAdminId           String?
  isActive                        Boolean                 @default(true)
  isSuspended                     Boolean                 @default(false)
  suspensionReason                String?
  isPro                           Boolean                 @default(false)
  hasUsedFreeExport               Boolean                 @default(false)
  createdAt                       DateTime                @default(now())
  updatedAt                       DateTime                @updatedAt
  deletedAt                       DateTime?
  /// OpenAI chat model IDs allowed for this company (set by Super Admin only). Empty until assigned.
  allowedOpenAiChatModels         String[]                @default([])
  aiCreditsMonthlyBase            Int                     @default(0)
  aiCreditsUsed                   Int                     @default(0)
  aiCreditsResetAt                DateTime
  aiStatus                        AiStatus                @default(ACTIVE)
  aiCreditsRemaining              Int                     @default(0)
  aiTokensPerCredit               Int                     @default(500)
  aiPromptTokensUsed              Int                     @default(0)
  aiCompletionTokensUsed          Int                     @default(0)
  aiTotalTokensUsed               Int                     @default(0)
  aiMonthlyPromptTokensUsed       Int                     @default(0)
  aiMonthlyCompletionTokensUsed   Int                     @default(0)
  aiMonthlyTokensUsed             Int                     @default(0)
  aiCreditsMonthlyManualOverride  Boolean                 @default(false)
  aiTokensPerCreditManualOverride Boolean                 @default(false)
  aiCreditsAddonRequests          AiCreditsAddonRequest[]
  aiTokenUsages                   AiTokenUsage[]
  aiTopups                        AiTopup[]
  apiKeys                         ApiKey[]
  assignmentRules                 AssignmentRule[]
  auditLogs                       AuditLog[]
  automationWorkflows             AutomationWorkflow[]
  cannedResponses                 CannedResponse[]
  chats                           Chat[]
  chatbotFlows                    ChatbotFlow[]
  createdBySuperAdmin             User?                   @relation("SuperAdminCreatedCompanies", fields: [createdBySuperAdminId], references: [id])
  crmFieldMappings                CrmFieldMapping[]
  crmIntegrations                 CrmIntegration[]
  crmSyncLogs                     CrmSyncLog[]
  customFields                    CustomField[]
  departments                     Department[]
  emailNotifications              EmailNotification[]
  faqs                            FAQ[]
  featureFlags                    FeatureFlag[]
  integrations                    Integration[]
  knowledgeChunks                 KnowledgeChunk[]
  knowledgeSources                KnowledgeSource[]
  leads                           Lead[]
  leadCrmLinks                    LeadCrmLink[]
  offlineForms                    OfflineForm[]
  proactiveTriggers               ProactiveTrigger[]
  properties                      Property[]
  quickReplies                    QuickReply[]
  slaRules                        SlaRule[]
  subscriptions                   Subscription[]
  tags                            Tag[]
  upgradeRequests                 UpgradeRequest[]
  users                           User[]
  visitors                        Visitor[]
  visitorEvents                   VisitorEvent[]
  visitorSegments                 VisitorSegment[]
  webhooks                        Webhook[]
  /// CRM lead sync UI prefs, e.g. `{ "primaryLeadSyncProvider": "HUBSPOT" }` when multiple CRMs are connected.
  crmLeadSyncPreferences          Json?

  @@index([deletedAt])
  @@index([isActive])
  @@index([isSuspended])
  @@index([createdBySuperAdminId])
  @@index([isPro])
  @@index([aiCreditsResetAt])
  @@index([aiStatus])
}

model AiTokenUsage {
  id                          String   @id @default(cuid())
  companyId                   String
  chatId                      String?
  promptTokens                Int      @default(0)
  completionTokens            Int      @default(0)
  totalTokens                 Int      @default(0)
  creditsConsumed             Int      @default(0)
  monthlyCreditsConsumed      Int      @default(0)
  topupCreditsConsumed        Int      @default(0)
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt
  /// Fractional credits (3 decimals) stored as integers (e.g. 0.35 => 350).
  creditsConsumedMilli        Int      @default(0)
  monthlyCreditsConsumedMilli Int      @default(0)
  topupCreditsConsumedMilli   Int      @default(0)
  chat                        Chat?    @relation(fields: [chatId], references: [id])
  company                     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([chatId])
  @@index([createdAt])
  @@index([companyId, createdAt])
}

model AiTopup {
  id                    String   @id @default(cuid())
  companyId             String
  creditsAdded          Int
  creditsRemaining      Int
  amount                Float
  createdAt             DateTime @default(now())
  /// Fractional credits (3 decimals) stored as integers (e.g. 1 credit => 1000).
  creditsAddedMilli     Int      @default(0)
  creditsRemainingMilli Int      @default(0)
  company               Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([companyId, createdAt])
  @@index([companyId, creditsRemaining])
}

model User {
  id                              String                  @id @default(cuid())
  companyId                       String?
  email                           String                  @unique
  name                            String?
  password                        String?
  role                            Role
  isOwner                         Boolean                 @default(false)
  isActive                        Boolean                 @default(false)
  emailVerified                   Boolean                 @default(false)
  avatarUrl                       String?
  deletedAt                       DateTime?
  inviteToken                     String?
  inviteExpires                   DateTime?
  emailVerificationToken          String?
  emailVerificationExpires        DateTime?
  passwordResetToken              String?
  passwordResetExpires            DateTime?
  lastSeen                        DateTime?               @default(now())
  timezone                        String?                 @default("UTC")
  twoFactorEnabled                Boolean                 @default(false)
  twoFactorSecret                 String?
  twoFactorBackupCodes            String[]                @default([])
  isSuperAdmin                    Boolean                 @default(false)
  createdAt                       DateTime                @default(now())
  updatedAt                       DateTime                @updatedAt
  agentAvailability               AgentAvailability?
  agentModuleAccess               AgentModuleAccess?
  agentPropertyAccess             AgentPropertyAccess[]
  processedAiCreditsAddonRequests AiCreditsAddonRequest[] @relation("ProcessedAiCreditsAddonRequests")
  apiKeys                         ApiKey[]
  attachments                     Attachment[]
  auditLogs                       AuditLog[]
  cannedResponses                 CannedResponse[]
  chats                           Chat[]                  @relation("AgentChats")
  chatNotes                       ChatNote[]
  chatRatings                     ChatRating[]
  chatTags                        ChatTag[]
  chatTranscripts                 ChatTranscript[]
  transfersFrom                   ChatTransfer[]          @relation("TransfersFrom")
  transfersTo                     ChatTransfer[]          @relation("TransfersTo")
  createdCompanies                Company[]               @relation("SuperAdminCreatedCompanies")
  departments                     DepartmentMember[]
  emailNotifications              EmailNotification[]
  messages                        Message[]               @relation("AgentMessages")
  messageReactions                MessageReaction[]
  readReceipts                    MessageReadReceipt[]
  offlineForms                    OfflineForm[]
  refreshTokens                   RefreshToken[]
  subscriptionChanges             SubscriptionChange[]
  processedUpgradeRequests        UpgradeRequest[]        @relation("ProcessedUpgradeRequests")
  company                         Company?                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  settings                        UserSettings?

  @@index([companyId])
  @@index([role])
  @@index([isActive])
  @@index([isSuperAdmin])
  @@index([deletedAt])
}

model UserSettings {
  id                   String    @id @default(cuid())
  userId               String    @unique
  notificationsEnabled Boolean   @default(true)
  chatSound            ChatSound @default(PING)
  theme                Theme     @default(LIGHT)
  browserAlerts        Boolean   @default(true)
  emailNotifications   Boolean   @default(true)
  desktopNotifications Boolean   @default(true)
  language             String    @default("en")
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
}

model Property {
  id                          String                @id @default(cuid())
  companyId                   String
  name                        String
  domain                      String?
  widgetKey                   String                @unique
  chatbotName                 String?
  chatbotLogo                 String?
  launcherButtonColor         String?
  primaryColor                String?
  backgroundColor             String?
  textColor                   String?
  leftMessageBackgroundColor  String?
  leftMessageTextColor        String?
  rightMessageBackgroundColor String?
  rightMessageTextColor       String?
  welcomeMessage              String?
  position                    String?               @default("right")
  showOnMobile                Boolean               @default(true)
  showOnDesktop               Boolean               @default(true)
  aiEnabled                   Boolean               @default(true)
  offlineFormEnabled          Boolean               @default(true)
  proactiveChatEnabled        Boolean               @default(false)
  removeBranding              Boolean               @default(false)
  createdAt                   DateTime              @default(now())
  deletedAt                   DateTime?
  /// Selected chat model for this widget (must be in company.allowedOpenAiChatModels when set)
  openAiChatModelId           String?
  /// Optional, tenant-defined system prompt injected into AI replies for this widget/property.
  customSystemPrompt          String?
  agentPropertyAccess         AgentPropertyAccess[]
  assignmentRules             AssignmentRule[]
  businessHours               BusinessHours?
  chats                       Chat[]
  chatbotFlows                ChatbotFlow[]
  faqs                        FAQ[]
  knowledgeChunks             KnowledgeChunk[]
  knowledgeSources            KnowledgeSource[]
  leads                       Lead[]
  offlineForms                OfflineForm[]
  proactiveTriggers           ProactiveTrigger[]
  company                     Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  quickReplies                QuickReply[]
  visitorEvents               VisitorEvent[]

  @@unique([companyId, domain])
  @@index([companyId])
  @@index([deletedAt])
}

model Visitor {
  id           String                 @id @default(cuid())
  companyId    String
  sessionId    String
  name         String?
  email        String?
  phone        String?
  ipAddress    String?
  userAgent    String?
  device       String?
  browser      String?
  country      String?
  city         String?
  timezone     String?
  firstSeen    DateTime               @default(now())
  lastSeen     DateTime?
  totalVisits  Int                    @default(1)
  externalId   String?
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  deletedAt    DateTime?
  /// Browser/widget visitor token (same value as sessionId; mirrors Chat.visitorToken)
  visitorToken String
  chats        Chat[]
  leads        Lead[]
  messages     Message[]              @relation("VisitorMessages")
  company      Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  events       VisitorEvent[]
  segments     VisitorSegmentMember[]
  tags         VisitorTag[]

  @@unique([companyId, visitorToken])
  @@index([companyId])
  @@index([sessionId])
  @@index([visitorToken])
  @@index([email])
  @@index([deletedAt])
}

model VisitorTag {
  id        String   @id @default(cuid())
  visitorId String
  tag       String
  createdAt DateTime @default(now())
  visitor   Visitor  @relation(fields: [visitorId], references: [id], onDelete: Cascade)

  @@unique([visitorId, tag])
  @@index([visitorId])
  @@index([tag])
}

model Chat {
  id             String               @id @default(cuid())
  companyId      String
  propertyId     String
  sessionId      String
  visitorId      String?
  agentId        String?
  departmentId   String?
  status         ChatStatus           @default(ACTIVE)
  priority       ChatPriority         @default(NORMAL)
  aiEnabled      Boolean              @default(true)
  subject        String?
  source         ChatSource?
  firstMessageAt DateTime?
  lastMessageAt  DateTime?
  assignedAt     DateTime?
  closedAt       DateTime?
  unreadCount    Int                  @default(0)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  deletedAt      DateTime?
  /// Browser/widget visitor token (widget uses the same value as sessionId)
  visitorToken   String
  aiTokenUsages  AiTokenUsage[]
  agent          User?                @relation("AgentChats", fields: [agentId], references: [id])
  company        Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  department     Department?          @relation(fields: [departmentId], references: [id])
  property       Property             @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  visitor        Visitor?             @relation(fields: [visitorId], references: [id])
  notes          ChatNote[]
  rating         ChatRating?
  tags           ChatTag[]
  transcript     ChatTranscript?
  transfers      ChatTransfer[]
  customFields   CustomFieldValue[]
  leads          Lead[]
  messages       Message[]            @relation("ChatMessages")
  readReceipts   MessageReadReceipt[]
  slaMetrics     SlaMetric[]
  events         VisitorEvent[]

  @@index([propertyId, sessionId])
  @@index([visitorToken])
  @@index([propertyId, visitorToken, createdAt])
  @@index([agentId])
  @@index([visitorId])
  @@index([status])
  @@index([priority])
  @@index([departmentId])
  @@index([createdAt])
  @@index([companyId, status, createdAt])
  @@index([propertyId, status, createdAt])
  @@index([agentId, status])
  @@index([lastMessageAt])
}

model Message {
  id                  String               @id @default(cuid())
  chatId              String
  senderType          SenderType
  messageType         MessageType          @default(TEXT)
  visitorId           String?
  agentId             String?
  botName             String?
  text                String?
  metadata            Json?
  clientMessageId     String?
  replyToClientMessageId String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  deletedAt           DateTime?
  isDeleted           Boolean              @default(false)
  editedAt            DateTime?
  attachments         Attachment[]
  agent               User?                @relation("AgentMessages", fields: [agentId], references: [id])
  chat                Chat                 @relation("ChatMessages", fields: [chatId], references: [id], onDelete: Cascade)
  visitor             Visitor?             @relation("VisitorMessages", fields: [visitorId], references: [id])
  messageButtons      MessageButton[]
  messageCards        MessageCard[]
  messageQuickReplies MessageQuickReply[]
  reactions           MessageReaction[]
  readReceipts        MessageReadReceipt[]

  @@index([chatId])
  @@index([visitorId])
  @@index([agentId])
  @@index([senderType])
  @@index([createdAt])
  @@index([deletedAt])
  @@index([chatId, createdAt])
  @@unique([chatId, senderType, clientMessageId])
  @@unique([chatId, senderType, replyToClientMessageId])
  @@index([deletedAt, createdAt])
}

model VisitorEvent {
  id           String   @id @default(cuid())
  companyId    String
  propertyId   String
  chatId       String?
  sessionId    String
  visitorId    String?
  eventType    String
  url          String?
  referrer     String?
  userAgent    String?
  device       String?
  browser      String?
  country      String?
  city         String?
  ipAddress    String?
  metadata     Json?
  createdAt    DateTime @default(now())
  /// Browser/widget visitor token (same value as sessionId; mirrors Chat.visitorToken)
  visitorToken String
  chat         Chat?    @relation(fields: [chatId], references: [id])
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  property     Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  visitor      Visitor? @relation(fields: [visitorId], references: [id])

  @@index([companyId])
  @@index([propertyId])
  @@index([visitorId])
  @@index([sessionId])
  @@index([visitorToken])
  @@index([propertyId, visitorToken, createdAt])
  @@index([chatId])
  @@index([eventType])
  @@index([createdAt])
}

model Lead {
  id           String             @id @default(cuid())
  companyId    String
  chatId       String?
  propertyId   String
  visitorId    String?
  fullName     String
  email        String?
  userId       String?
  phone        String?
  companyName  String?
  notes        String?
  status       LeadStatus         @default(NEW)
  source       LeadSource         @default(WEBSITE)
  channel      String             @default("web_widget")
  externalId   String?
  syncedAt     DateTime?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  crmSyncLogs  CrmSyncLog[]
  customFields CustomFieldValue[]
  chat         Chat?              @relation(fields: [chatId], references: [id])
  company      Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  property     Property           @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  visitor      Visitor?           @relation(fields: [visitorId], references: [id])
  crmLinks     LeadCrmLink[]

  @@index([companyId])
  @@index([propertyId])
  @@index([chatId])
  @@index([email])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model CrmIntegration {
  id                     String               @id @default(cuid())
  companyId              String
  provider               CrmProvider
  status                 CrmIntegrationStatus @default(CONNECTED)
  encryptedAccessToken   String?
  encryptedRefreshToken  String?
  tokenExpiresAt         DateTime?
  encryptedWebhookUrl    String?
  encryptedWebhookSecret String?
  settings               Json?
  lastSyncAt             DateTime?
  lastError              String?
  createdById            String?
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
  company                Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  syncLogs               CrmSyncLog[]

  @@unique([companyId, provider])
  @@index([companyId])
  @@index([provider])
  @@index([status])
}

model CrmFieldMapping {
  id        String        @id @default(cuid())
  companyId String
  provider  CrmProvider
  source    CrmLeadSource
  mappings  Json
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  company   Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, provider, source])
  @@index([companyId])
  @@index([provider, source])
}

model CrmSyncLog {
  id              String          @id @default(cuid())
  companyId       String
  integrationId   String?
  leadId          String?
  chatId          String?
  provider        CrmProvider
  action          CrmSyncAction
  trigger         CrmSyncTrigger
  status          CrmSyncStatus   @default(PENDING)
  requestPayload  Json?
  responsePayload Json?
  errorMessage    String?
  retryCount      Int             @default(0)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  company         Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  integration     CrmIntegration? @relation(fields: [integrationId], references: [id])
  lead            Lead?           @relation(fields: [leadId], references: [id])

  @@index([companyId])
  @@index([integrationId])
  @@index([leadId])
  @@index([chatId])
  @@index([provider])
  @@index([status])
  @@index([createdAt])
}

model LeadCrmLink {
  id           String      @id @default(cuid())
  companyId    String
  leadId       String
  provider     CrmProvider
  crmContactId String?
  crmDealId    String?
  lastSyncedAt DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  company      Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lead         Lead        @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@unique([companyId, leadId, provider])
  @@index([companyId])
  @@index([leadId])
  @@index([provider])
  @@index([crmContactId])
}

model KnowledgeSource {
  id         String           @id @default(cuid())
  companyId  String
  propertyId String
  sourceType SourceType
  title      String
  content    String?
  url        String?
  filePath   String?
  fileName   String?
  fileSize   Int?
  status     KnowledgeStatus  @default(PENDING)
  chunkCount Int              @default(0)
  error      String?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  deletedAt  DateTime?
  chunks     KnowledgeChunk[]
  company    Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  property   Property         @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([propertyId])
  @@index([sourceType])
  @@index([status])
  @@index([deletedAt])
}

model KnowledgeChunk {
  id              String                 @id @default(cuid())
  companyId       String
  sourceId        String
  propertyId      String
  content         String
  chunkIndex      Int
  embedding       Unsupported("vector")?
  embeddingVendor EmbeddingVendor?
  embeddingModel  String?
  embeddingDim    Int?
  metadata        Json?
  createdAt       DateTime               @default(now())
  company         Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  property        Property               @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  source          KnowledgeSource        @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@unique([sourceId, chunkIndex])
  @@index([companyId, embeddingVendor, embeddingModel])
  @@index([sourceId])
  @@index([propertyId])
  @@index([chunkIndex])
}

model MessageButton {
  id        String   @id @default(cuid())
  messageId String
  label     String
  value     String
  type      String   @default("postback")
  url       String?
  payload   String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@index([order])
}

model MessageCard {
  id        String              @id @default(cuid())
  messageId String
  title     String
  subtitle  String?
  imageUrl  String?
  order     Int                 @default(0)
  createdAt DateTime            @default(now())
  message   Message             @relation(fields: [messageId], references: [id], onDelete: Cascade)
  buttons   MessageCardButton[]

  @@index([messageId])
  @@index([order])
}

model MessageCardButton {
  id      String      @id @default(cuid())
  cardId  String
  label   String
  value   String
  type    String      @default("postback")
  url     String?
  payload String?
  order   Int         @default(0)
  card    MessageCard @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([cardId])
  @@index([order])
}

model MessageQuickReply {
  id        String  @id @default(cuid())
  messageId String
  label     String
  payload   String
  imageUrl  String?
  order     Int     @default(0)
  message   Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@index([order])
}

model Subscription {
  id                    String               @id @default(cuid())
  companyId             String
  planTier              PlanTier             @default(FREE)
  billingCycle          BillingCycle?
  status                SubscriptionStatus   @default(ACTIVE)
  currentPeriodStart    DateTime?
  currentPeriodEnd      DateTime?
  cancelAtPeriodEnd     Boolean              @default(false)
  stripeCustomerId      String?              @unique
  stripeSubscriptionId  String?              @unique
  stripePriceId         String?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  subscriptionStartDate DateTime?
  billingAnchorDay      Int?
  nextBillingAt         DateTime?
  invoices              Invoice[]
  company               Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  changes               SubscriptionChange[]
  usageRecords          UsageRecord[]

  @@unique([companyId])
  @@index([status])
  @@index([planTier])
}

model SubscriptionChange {
  id                    String              @id @default(cuid())
  subscriptionId        String
  changedBySuperAdminId String
  action                SubscriptionAction
  oldPlanTier           PlanTier?
  newPlanTier           PlanTier?
  oldStatus             SubscriptionStatus?
  newStatus             SubscriptionStatus?
  reason                String?
  createdAt             DateTime            @default(now())
  changedBySuperAdmin   User                @relation(fields: [changedBySuperAdminId], references: [id], onDelete: Cascade)
  subscription          Subscription        @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId])
  @@index([changedBySuperAdminId])
}

model Invoice {
  id              String        @id @default(cuid())
  subscriptionId  String
  amount          Float
  currency        String        @default("usd")
  status          InvoiceStatus
  stripeInvoiceId String?       @unique
  invoiceUrl      String?
  pdfUrl          String?
  periodStart     DateTime
  periodEnd       DateTime
  createdAt       DateTime      @default(now())
  paidAt          DateTime?
  subscription    Subscription  @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId])
  @@index([status])
}

model UsageRecord {
  id             String       @id @default(cuid())
  subscriptionId String
  metric         String
  quantity       Int
  limit          Int?
  periodStart    DateTime
  periodEnd      DateTime
  createdAt      DateTime     @default(now())
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId])
  @@index([metric])
}

model UpgradeRequest {
  id            String    @id @default(cuid())
  companyId     String
  name          String
  companyName   String
  email         String
  phone         String?
  message       String?
  status        String    @default("PENDING")
  notes         String?
  processedById String?
  processedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  company       Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  processedBy   User?     @relation("ProcessedUpgradeRequests", fields: [processedById], references: [id])

