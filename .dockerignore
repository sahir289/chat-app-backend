# Everything here is EXCLUDED from the Docker build context. A smaller context
# means faster builds, smaller images, and — critically — no secrets baked in.

# Dependencies are reinstalled inside the image via "npm ci", never copied.
node_modules

# Build output is regenerated by "npm run build" inside the image.
dist

# NEVER ship local secrets into an image. Config comes from K8s Secrets/ConfigMaps.
.env
.env.*
!.env.example

# Local noise that has no business in a production image.
logs
*.log
.git
.gitignore
.github
.vscode
.idea
coverage
*.md
!README.md

# Local-only tooling and test artifacts.
docker-compose*.yml
Dockerfile
.dockerignore
deploy
vitest.config.ts
eslint.config.js
