DATABASE_URL=""

NODE_ENV=
PORT=
TRUST_PROXY=

# OpenAI
OPENAI_PRO_API_KEY=""

# Security
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
ENCRYPTION_KEY=""
JWT_EXPIRES_IN=

 
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=
SUPER_ADMIN_NAME=

# SMTP Email Configuration
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=
SMTP_USER=
SMTP_PASS=
INVITE_FROM_EMAIL=

# Comma-separated allowed origins (e.g. https://mitravarta.com,https://www.mitravarta.com)
CORS_ORIGINS=

# Optional: max request body size for urlencoded (default 25mb). For file uploads, ensure your reverse proxy (e.g. Nginx client_max_body_size) allows at least this.
# BODY_LIMIT=25mb

# AWS S3 Configuration
AWS_REGION=""
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_S3_BUCKET_NAME=""
AWS_S3_BUCKET_URL=""
AWS_S3_USE_ACL=

# RATE LIMIT
LOGIN_MAX_ATTEMPTS=
LOGIN_2FA_MAX_ATTEMPTS=
PASSWORD_RESET_MAX_ATTEMPTS=

# Platform Name
PLATFORM_NAME=

# Kylas CRM lead sync
# API docs use POST https://api.kylas.io/v1/leads/ with an api-key header.
KYLAS_API_KEY=
KYLAS_API_BASE_URL=https://api.kylas.io/v1
# Optional request timeout in milliseconds.
# KYLAS_TIMEOUT_MS=10000
# Post registration leads to Kylas: defaults to on only when NODE_ENV=production. Set false for prod-like staging, or true to test locally.
# KYLAS_ACCOUNT_LEAD_SYNC_ENABLED=

# Public web app URL (one variable is enough). Emails, invites, and auth links use this; widget iframe defaults to APP_URL/embed.
APP_URL=
# Optional aliases if you already use frontend naming elsewhere (same value as APP_URL; do not duplicate in .env)
# NEXT_PUBLIC_APP_URL=
# NEXT_PUBLIC_FRONTEND_URL=

# Invite links only if they must differ from APP_URL (e.g. different subdomain)
# INVITE_BASE_URL=

# Logging
LOG_LEVEL=info

# Widget URLs (set per environment for white-label / multi-domain)
WIDGET_BACKEND_URL=
# Only if embed is not at APP_URL/embed
# WIDGET_EMBED_URL=

# redis
REDIS_URL=

# Default: 900000 (15 minutes)
AUTH_RATE_LIMIT_WINDOW_MS=900000

# Registration Rate Limits
REGISTER_MAX_ATTEMPTS=5

# Password Reset Rate Limits
FORGOT_PASSWORD_MAX_ATTEMPTS=2
RESET_PASSWORD_MAX_ATTEMPTS=5

# Email Rate Limits
EMAIL_RESEND_MAX_ATTEMPTS=2
VERIFY_EMAIL_WINDOW_MS=60000
VERIFY_EMAIL_MAX_ATTEMPTS=30

# Two-Factor Authentication Rate Limits
TWO_FA_VERIFICATION_MAX_ATTEMPTS=10
TWO_FA_VERIFY_MAX_ATTEMPTS=5
TWO_FA_TOTP_WINDOW=1
TWO_FA_BACKUP_CODES_COUNT=10

# Refresh Token Rate Limits
REFRESH_TOKEN_WINDOW_MS=300000
REFRESH_TOKEN_MAX_ATTEMPTS=60
ACCESS_TOKEN_MAX_AGE_MS=3600000
REFRESH_COOKIE_MAX_AGE_MS=2592000000

# Invite Rate Limits
ACCEPT_INVITE_WINDOW_MS=600000
ACCEPT_INVITE_MAX_ATTEMPTS=10
VALIDATE_INVITE_WINDOW_MS=60000
VALIDATE_INVITE_MAX_ATTEMPTS=30

NPM_VERSION=
