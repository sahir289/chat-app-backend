DATABASE_URL=
IS_CROSS_SITE=false

NODE_ENV=development
PORT=4000
TRUST_PROXY=true

# OpenAI
OPENAI_PRO_API_KEY=

# Security
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
ENCRYPTION_KEY=""
JWT_EXPIRES_IN=30d
JWT_ACCESS_EXPIRES_IN=1h

SUPER_ADMIN_PASSWORD=
SUPER_ADMIN_NAME=Super Admin

# SMTP Email Configuration
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=
SMTP_USER=
SMTP_PASS=
SUPER_ADMIN_EMAIL=
INVITE_FROM_EMAIL=

# AWS S3 Configuration
AWS_REGION=""
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_S3_BUCKET_NAME=""
AWS_S3_BUCKET_URL=""
AWS_S3_USE_ACL=

# RATE LIMIT
LOGIN_MAX_ATTEMPTS=100
LOGIN_2FA_MAX_ATTEMPTS=50
PASSWORD_RESET_MAX_ATTEMPTS=3

# Platform Name
PLATFORM_NAME=

# kylas
KYLAS_API_KEY=
KYLAS_API_BASE_URL=
KYLAS_PIPELINE_ID=
KYLAS_PIPELINE_STAGE_ID=
KYLAS_PROJECT_TITLE_ID=
KYLAS_LEAD_SUB_SOURCE=
KYLAS_UTM_SOURCE=
KYLAS_UTM_MEDIUM=
KYLAS_UTM_CAMPAIGN=
# Set true to test registration → Kylas locally (production defaults to on when NODE_ENV=production)
KYLAS_ACCOUNT_LEAD_SYNC_ENABLED=

CORS_ORIGINS=http://localhost:3000

# Public web app (emails, invites, auth links; widget uses APP_URL/embed by default)
APP_URL=http://localhost:3000

# Logging
LOG_LEVEL=info

# Widget URLs
WIDGET_BACKEND_URL=http://localhost:4000

# redis
REDIS_URL=redis://localhost:6379


# Default: 900000 (15 minutes)
AUTH_RATE_LIMIT_WINDOW_MS=900000

# Registration Rate Limits
REGISTER_MAX_ATTEMPTS=10

# Password Reset Rate Limits
FORGOT_PASSWORD_MAX_ATTEMPTS=2
RESET_PASSWORD_MAX_ATTEMPTS=5

# Email Rate Limits
EMAIL_RESEND_MAX_ATTEMPTS=5
VERIFY_EMAIL_WINDOW_MS=60000
VERIFY_EMAIL_MAX_ATTEMPTS=30

# Two-Factor Authentication Rate Limits
TWO_FA_VERIFICATION_MAX_ATTEMPTS=10
TWO_FA_VERIFY_MAX_ATTEMPTS=5
TWO_FA_TOTP_WINDOW=1
TWO_FA_BACKUP_CODES_COUNT=10

# Refresh Token Rate Limits
REFRESH_TOKEN_WINDOW_MS=300000
REFRESH_TOKEN_MAX_ATTEMPTS=60
ACCESS_TOKEN_MAX_AGE_MS=3600000
REFRESH_COOKIE_MAX_AGE_MS=2592000000

# Invite Rate Limits
ACCEPT_INVITE_WINDOW_MS=600000
ACCEPT_INVITE_MAX_ATTEMPTS=10
VALIDATE_INVITE_WINDOW_MS=60000
VALIDATE_INVITE_MAX_ATTEMPTS=30

# Attachment uploads — optional ClamAV (TCP). Magic-byte validation always runs.
ATTACHMENT_MALWARE_SCAN=required
CLAMAV_HOST=127.0.0.1
CLAMAV_PORT=3310
CLAMAV_TIMEOUT_MS=30000

NPM_VERSION=1.0.0

# serviots website analytics api url and api key
SERVIOTS_ANALYTICS_BASE_URL=
ANALYTICS_ADMIN_API_KEY=

IP_HASH_SALT=
IP_ENCRYPTION_KEY=

WEBSITE_ANALYTICS_RETENTION_DAYS=730
REDIS_REQUIRED=true
WEBSITE_ANALYTICS_TRACK_RATE_MAX_PER_IP=600
WEBSITE_ANALYTICS_TRACK_RATE_MAX_PER_VISITOR=120
WEBSITE_ANALYTICS_TRACK_RATE_WINDOW_MS=60000